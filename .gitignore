# Runtime state — never commit
.omc/
# .claude/ is maintainer-local Claude Code state, not shipped product (the
# plugin ships via package.json "files": commands/ hooks/ skills/ templates/
# .claude-plugin/). Personal dev-workflow commands (qa-features, qa-before-ship)
# live in the maintainer's own ~/.claude/commands/, not here.
.claude/

# Node
node_modules/
dist/
build/

# OS
.DS_Store
*.swp

# Secrets
.env*
*.pem
*credentials*
*secret*
